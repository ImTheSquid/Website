---
interface Props {
  alwaysCenter?: boolean;
  blogInfo?: { title: string; tagline: string };
}
const { alwaysCenter = false, blogInfo = null } = Astro.props;
const hnTitle = blogInfo ? encodeURI(`${blogInfo.title}: ${blogInfo.tagline}`) : null;
const isBlog = !!blogInfo;
const year = new Date().getFullYear();
const toggleColorStyle = isBlog ? "hidden md:flex" : "flex";
---

<footer class="mt-4 w-full">
  {
    isBlog && (
      <div class="justify-center flex mb-2 flex-col">
        <a
          href=`https://news.ycombinator.com/submitlink?u=${Astro.url}&t=${hnTitle}`
          target="_blank"
          class="underline decoration-1 hover:decoration-2 mx-auto p-2 text-xl"
        >
          Share to HN
        </a>
        <div class="mx-auto text-lg">
            <a
              href="/blog"
              class="hover:underline p-2 hover:-translate-x-1 transition-transform mx-auto inline-block"
            >
              ← Back to Blogs ←
            </a>
            <button
              class="hover:underline p-2 hover:-translate-y-1 transition-transform cursor-pointer"
              onclick="window.scrollTo({top: 0, behavior: 'smooth'});"
            >
              ↑ Back to Top ↑
            </button>

        </div >

      </div>
    )
  }

  <div
    class=`w-full ${toggleColorStyle} ${alwaysCenter ? "" : "md:justify-normal"} justify-center mb-2`
  >
    <button
      class="cursor-pointer underline hover:decoration-2"
      onclick="document.dispatchEvent(new CustomEvent('colortoggle', { detail: {} }))"
      >Toggle Color</button
    >
    <span class="px-1">|</span>
    <button
      class="cursor-pointer underline hover:decoration-2"
      onclick="document.dispatchEvent(new CustomEvent('noisetoggle', { detail: {} }))"
      >Toggle Noise</button
    >
  </div>

  <div
    class=`flex flex-row text-lg font-sans justify-center ${alwaysCenter ? "" : "md:justify-normal"}`
  >
    <a
      href="https://ring.purduehackers.com/previous?host=jackhogan.me"
      class="hover:underline pr-1 py-1 hover:-translate-x-1 transition-transform"
      >←</a
    >
    <a
      href="https://ring.purduehackers.com"
      target="_blank"
      class="hover:underline font-bold p-1">Purdue Hackers</a
    >
    <a
      href="https://ring.purduehackers.com/next?host=jackhogan.me"
      class="hover:underline pl-1 py-1 hover:translate-x-1 transition-transform"
      >→</a
    >
  </div>

  <p
    class=`font-mono mt-2 text-lg text-center ${alwaysCenter ? "" : "md:text-start"} mb-10 md:mb-0`
  >
    © {year} Jack Hogan
  </p>
</footer>
